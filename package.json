{
  "name": "bitewise-backend",
  "version": "1.0.0",
  "description": "Web Development course final project - backend",
  "main": "index.js",
  "scripts": {
    "start": "tsc && node --env-file=.env.dev ./dist/src/server.js",
    "dev": "nodemon ./src/server.ts",
    "test": "tsc && jest --detectOpenHandles --forceExit --runInBand",
    "testPost": "tsc && jest --detectOpenHandles --forceExit --runInBand ./src/tests/post.test.ts",
    "testComment": "tsc && jest --detectOpenHandles --forceExit --runInBand ./src/tests/comment.test.ts",
    "testAuth": "tsc && jest --detectOpenHandles --forceExit --runInBand ./src/tests/auth.test.ts",
    "test:coverage": "tsc && jest --detectOpenHandles --forceExit --runInBand --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liadshe/BiteWise-backend.git"
  },
  "keywords": [],
