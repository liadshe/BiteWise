{
  "name": "bitewise-backend",
  "version": "1.0.0",
  "description": "Web Development course final project - backend",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "tsc && node --env-file=.env.dev ./dist/server.js",
    "dev": "nodemon --exec \"node --env-file=.env.dev -r ts-node/register\" src/server.ts",
    "test": "tsc && jest --detectOpenHandles --forceExit --runInBand",
    "testPost": "tsc && jest --detectOpenHandles --forceExit --runInBand ./src/tests/post.test.ts",
    "testComment": "tsc && jest --detectOpenHandles --forceExit --runInBand ./src/tests/comment.test.ts",
    "testAuth": "tsc && jest --detectOpenHandles --forceExit --runInBand ./src/tests/auth.test.ts",
    "test:coverage": "tsc && jest --detectOpenHandles --forceExit --runInBand --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liadshe/BiteWise-backend.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/liadshe/BiteWise-backend/issues"
  },
  "homepage": "https://github.com/liadshe/BiteWise-backend#readme",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.13.5",
    "bootstrap": "^5.3.8",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.19.4",
    "multer": "^2.1.0",
    "react-hook-form": "^7.71.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "bcrypt": "^6.0.0",
    "eslint": "^9.39.3",
